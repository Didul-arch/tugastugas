	url = {https://ieeexplore.ieee.org/document/9187880/},
	doi = {10.1109/JIOT.2020.3022358},
	abstract = {Beneﬁting from the advance of Deep Learning technology, IoT devices and systems are becoming more intelligent and multi-functional. They are expected to run various Deep Learning inference tasks with high efﬁciency and performance. This requirement is challenged by the mismatch between the limited computing capability of edge devices and large-scale Deep Neural Networks. Edge-cloud collaborative systems are then introduced to mitigate this conﬂict, enabling resource-constrained IoT devices to host arbitrary Deep Learning applications.},
	language = {en},
	number = {12},
	urldate = {2026-04-12},
	journal = {IEEE Internet of Things Journal},
	author = {He, Zecheng and Zhang, Tianwei and Lee, Ruby B.},
	month = jun,
